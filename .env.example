APP_ENV=local
APP_DEBUG=false
APP_URL=http://localhost:8080
APP_KEY=base64:replace-with-32-byte-sodium-key
SESSION_NAME=ai_chatbot_portal
ADMIN_API_TOKEN=replace-with-random-admin-token

DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=ai_chatbot_portal
DB_USERNAME=chatbot
DB_PASSWORD=change-this-password

DEFAULT_PROVIDER=openai
PROVIDER_TIMEOUT_SECONDS=45
PROVIDER_RETRY_ATTEMPTS=2
OPENAI_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
GEMINI_MODEL=gemini-1.5-flash
DEEPSEEK_MODEL=deepseek-chat

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
RAG_TOP_K=6
RAG_CHUNK_TOKENS=650
RAG_CHUNK_OVERLAP=90

DATA_RESIDENCY_REGION=UAE
AUDIT_RETENTION_DAYS=365
CHAT_RETENTION_DAYS=180
MAX_UPLOAD_MB=25
RATE_LIMIT_PER_MINUTE=30
ADMIN_MFA_REQUIRED=true
